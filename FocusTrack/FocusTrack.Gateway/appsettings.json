{
  "Auth": {
    "Authority": "",
    "Domain": "",
    "ClientId": "",
    "ClientSecret": "",
    "Audience": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "ReverseProxy": {
    "Routes": {
      "session-route": {
        "ClusterId": "session-cluster",
        "Match": { "Path": "/api/sessions/{**catch-all}" }
      },
      "admin-route": {
        "ClusterId": "session-cluster",
        "Match": { "Path": "/admin/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "session-cluster": {
        "Destinations": {
          "session1": { "Address": "http://session-service:8080/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification1": { "Address": "http://notification-service:8080/" }
        }
      }
    }
  },
  "Jaeger": { "Host": "jaeger" },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning" }
    }
  }
}
